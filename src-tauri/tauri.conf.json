{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Bookkeeping",
  "version": "0.1.0",
  "identifier": "com.bookkeeping.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bookkeeping",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright 2025",
    "shortDescription": "Double-entry bookkeeping desktop app",
    "longDescription": "A double-entry bookkeeping desktop application built with Tauri, React, and SQLite. Your data stays in standard .sqlite files that you own.",
    "category": "Finance"
  }
}
